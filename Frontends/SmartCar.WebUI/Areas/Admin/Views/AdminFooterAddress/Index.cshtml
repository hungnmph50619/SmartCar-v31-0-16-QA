@model List<ResultFooterAddressDto>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xl-12">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">Trang địa chỉ liên hệ và chân trang</h4>
                        <p class="card-subtitle mb-4">
                            Tại đây, bạn có thể quản lý địa chỉ hiển thị trong phần Liên hệ và chân trang. Có thể lấy vị trí bản đồ từ Google Maps.
                        </p>
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>Địa chỉ</th>
                                        <th>Điện thoại</th>
                                        <th>E-Mail</th>
                                        <th>Mô tả</th>
                                        <th>Xóa</th>
                                        <th>Cập nhật</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.Address</td>
                                            <td>@item.Phone</td>
                                            <td>@item.Email</td>
                                            <td>@item.Description</td>
                                            <td><form method="post" action="/Admin/AdminFooterAddress/RemoveFooterAddress/@item.FooterAddressID" class="d-inline" onsubmit="return confirm('Bạn chắc chắn muốn xóa dữ liệu này?');">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-outline-danger">Xóa</button>
</form></td>
                                            <td><a href="/Admin/AdminFooterAddress/UpdateFooterAddress/@item.FooterAddressID" class="btn btn-outline-success">Cập nhật</a></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            <a href="/Admin/AdminFooterAddress/CreateFooterAddress" class="btn btn-outline-primary">Thêm địa chỉ mới</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
