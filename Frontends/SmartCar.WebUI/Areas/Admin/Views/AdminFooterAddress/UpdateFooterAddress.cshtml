@model UpdateFooterAddressDto

@{
    ViewData["Title"] = "UpdateFooterAddress";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}


<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xl-12">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">Thêm thông tin địa chỉ mới</h4>
                        <p class="card-subtitle mb-4">Bạn có thể cập nhật thông tin địa chỉ chân trang ở biểu mẫu bên dưới.</p>
                        <form method="post">@Html.AntiForgeryToken()
                            <input type="hidden" asp-for="FooterAddressID" />
                            <div class="form-group">
                                <label for="exampleInputAddress">Địa chỉ</label>
                                <input type="text" class="form-control" id="exampleInputAddress" asp-for="Address" placeholder="Nhập địa chỉ">
                            </div>
                            <div class="form-group">
                                <label for="exampleInputDescription">Mô tả</label>
                                <input type="text" class="form-control" id="exampleInputDescription" asp-for="Description" placeholder="Nhập mô tả">
                            </div>
                            <div class="form-group">
                                <label for="exampleInputPhone">Số điện thoại</label>
                                <input type="tel" class="form-control" id="exampleInputPhone" asp-for="Phone" placeholder="Nhập số điện thoại">
                            </div>
                            <div class="form-group">
                                <label for="exampleInputMail">Địa chỉ email</label>
                                <input type="email" class="form-control" id="exampleInputMail" asp-for="Email" placeholder="Hãy nhập địa chỉ email">
                            </div>
                            <button type="submit" class="btn btn-primary waves-effect waves-light">Lưu địa chỉ</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

