@model UpdateBannerDto

@{
    ViewData["Title"] = "UpdateBanner";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xl-12">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">Thêm thông tin banner mới</h4>
                        <p class="card-subtitle mb-4">Bạn có thể nhập dữ liệu banner từ bảng bên dưới. Để tránh lỗi bố cục, sau khi thêm banner mới hãy xóa banner cũ và chỉ giữ lại một bản ghi.</p>
                        <form method="post">@Html.AntiForgeryToken()
                            <input type="hidden" asp-for="BannerID" />
                            <div class="form-group">
                                <label for="exampleInputTitle">Tiêu đề</label>
                                <input type="text" class="form-control" id="exampleInputTitle" asp-for="Title" placeholder="Nhập tiêu đề">
                            </div>
                            <div class="form-group">
                                <label for="exampleInputDescription">Mô tả</label>
                                <input type="text" class="form-control" id="exampleInputDescription" asp-for="Description" placeholder="Nhập mô tả">
                            </div>
                            <div class="form-group">
                                <label for="exampleInputVideoDescription">Mô tả video</label>
                                <input type="text" class="form-control" id="exampleInputVideoDescription" asp-for="VideoDescription" placeholder="Nhập mô tả video">
                            </div>
                            <div class="form-group">
                                <label for="exampleInputVideoUrl">Video Url</label>
                                <input type="text" class="form-control" id="exampleInputVideoUrl" asp-for="VideoUrl" placeholder="Video'nun Youtube Embed Linkini Hãy nhập">
                            </div>
                            <button type="submit" class="btn btn-success waves-effect waves-light">Cập nhật banner</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


