@model List<ResultCommentDto>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xl-12">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">Danh sách bình luận - BlogID: @ViewBag.v</h4>
                        <p class="card-subtitle mb-4">
                            Bạn có thể xem danh sách bình luận của bài viết tại đây, đồng thời xóa hoặc kích hoạt lại bình luận bằng các nút bên dưới.
                        </p>
                        @if (TempData["CommentError"] != null)
                        {
                            <div class="alert alert-danger">@TempData["CommentError"]</div>
                        }
                        @foreach(var item in Model ?? new List<ResultCommentDto>())
                        {
                            count++;
                            <div class="col-md-12">
                                <div class="card">
                                    <h5 class="card-header">Bình luận - @count</h5>
                                    <div class="card-body">
                                        <h4 class="card-title">@item.Name</h4>
                                        <p class="card-text">
                                           @item.Description.
                                        </p>
                                        <form method="post" action="/Admin/AdminComment/RemoveComment" onsubmit="return confirm('Bạn có chắc muốn xóa bình luận này?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.CommentID" />
                                            <input type="hidden" name="blogId" value="@item.BlogID" />
                                            <button type="submit" class="btn btn-danger waves-effect waves-light">Xóa bình luận</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>




