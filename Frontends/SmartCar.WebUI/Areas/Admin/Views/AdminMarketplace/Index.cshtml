@model AdminMarketplaceViewModel
@{
    ViewData["Title"] = "Hoa hồng và đối soát";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="page-content"><div class="container-fluid">
    <div class="d-flex justify-content-between mb-3"><div><h3>Hoa hồng và đối soát sàn xe đối tác</h3><p class="text-muted">Smart Car không sở hữu xe; doanh thu nền tảng đến từ hoa hồng trên đơn thuê hoàn thành.</p></div><a href="/Admin/AdminVehiclePartner/Index" class="btn btn-outline-primary">Hồ sơ và xe đối tác</a></div>
    @if(TempData["MarketplaceSuccess"]!=null){<div class="alert alert-success">@TempData["MarketplaceSuccess"]</div>}
    @if(TempData["MarketplaceError"]!=null){<div class="alert alert-danger">@TempData["MarketplaceError"]</div>}

    @if(User.IsInRole("Admin")){
    <div class="card mb-4"><div class="card-body"><h4>Cấu hình hoa hồng mặc định</h4><form method="post" action="/Admin/AdminMarketplace/UpdateSettings">@Html.AntiForgeryToken()<div class="row align-items-end"><div class="col-md-3 form-group"><label>Hoa hồng Smart Car (%)</label><input name="VehiclePartnerCommissionPercent" type="number" min="0" max="100" step="0.1" value="@Model.Settings.VehiclePartnerCommissionPercent.ToString("0.##")" class="form-control"/></div><div class="col-md-6 form-group"><label>Ghi chú thay đổi</label><input name="Note" value="@Model.Settings.Note" class="form-control"/></div><div class="col-md-3 form-group"><button class="btn btn-primary btn-block">Lưu cấu hình</button></div></div></form><small class="text-muted">Tỷ lệ mới chỉ áp dụng cho đơn tạo sau thời điểm cập nhật. Đơn cũ giữ nguyên tỷ lệ đã chốt.</small></div></div>}

    <div class="card"><div class="card-body"><div class="d-flex justify-content-between align-items-center mb-3"><h4>Giao dịch đối soát chủ xe</h4><form method="get" class="form-inline"><select name="status" class="form-control mr-2"><option value="">Tất cả trạng thái</option><option>Chờ đối soát</option><option>Đã đối soát</option><option>Đã thanh toán</option><option>Tạm giữ do tranh chấp</option><option>Đã hủy</option></select><button class="btn btn-secondary">Lọc</button></form></div>
    <div class="table-responsive"><table class="table table-bordered"><thead><tr><th>Chủ xe</th><th>Đơn thuê</th><th>Doanh thu gộp</th><th>Phí Smart Car</th><th>Đối tác nhận</th><th>Trạng thái</th><th>Thao tác</th></tr></thead><tbody>
        @foreach(var tx in Model.Transactions){<tr><td>@tx.PartnerName</td><td>@tx.Reference<br/><small>@tx.CreatedDate.ToString("dd/MM/yyyy HH:mm")</small></td><td>@tx.GrossAmount.ToString("#,0", CultureInfo.InvariantCulture)</td><td>@tx.CommissionRate.ToString("0.##")%<br/><strong>@tx.CommissionAmount.ToString("#,0", CultureInfo.InvariantCulture)</strong></td><td><strong>@tx.PartnerNetAmount.ToString("#,0", CultureInfo.InvariantCulture)</strong></td><td>@tx.Status@if(!string.IsNullOrWhiteSpace(tx.BankReference)){<br/><small>Mã GD: @tx.BankReference</small>}</td><td><a class="btn btn-sm btn-outline-primary" href="/ReservationLookup/Details?id=@tx.ReservationID">Mở Settlement của đơn</a><div class="small text-muted mt-1">Chỉ đọc; trạng thái được đồng bộ khi Settlement được chi trả.</div></td></tr>}
        @if(!Model.Transactions.Any()){<tr><td colspan="7" class="text-center text-muted">Chưa có giao dịch đối soát.</td></tr>}
    </tbody></table></div></div></div>
</div></div>
