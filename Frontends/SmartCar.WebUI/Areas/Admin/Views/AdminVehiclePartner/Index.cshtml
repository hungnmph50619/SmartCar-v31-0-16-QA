@model AdminVehiclePartnerViewModel
@{
    ViewData["Title"] = "Đối tác chủ xe";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    var selectedStatus = ViewBag.SelectedStatus as string;
}
<style>
    .review-card{border:1px solid #e6eaf0;border-radius:12px;padding:16px;margin-bottom:14px;background:#fff}
    .review-cover{height:150px;width:100%;object-fit:cover;border-radius:10px;background:#f4f6f8}
    .meta-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px 18px}
    .meta-item{font-size:.92rem}.meta-item strong{display:block;color:#536273;font-size:.78rem;text-transform:uppercase}
    .status-tabs .btn{margin:0 6px 6px 0}.empty-state{padding:40px;text-align:center;color:#6c757d}
    @@media(max-width:767px){.meta-grid{grid-template-columns:1fr}.review-cover{height:200px}}
</style>
<div class="page-content"><div class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
        <div><h3 class="mb-1">Đối tác chủ xe</h3><p class="text-muted mb-0">Xét duyệt hồ sơ theo trang chi tiết riêng. Chiết khấu chung: @Model.GlobalCommissionRate.ToString("0.##")%</p></div>
        <a href="/Admin/AdminMarketplace/Index" class="btn btn-primary">Đối soát & chiết khấu</a>
    </div>
    @if(TempData["MarketplaceSuccess"]!=null){<div class="alert alert-success">@TempData["MarketplaceSuccess"]</div>}
    @if(TempData["MarketplaceError"]!=null){<div class="alert alert-danger">@TempData["MarketplaceError"]</div>}

    <div class="card mb-4"><div class="card-body">
        <div class="d-flex flex-wrap align-items-center mb-3"><h4 class="mr-3 mb-0">Hồ sơ đối tác</h4><span class="badge badge-warning p-2">@Model.Profiles.Count(x=>x.Status=="Chờ duyệt") chờ duyệt</span></div>
        @foreach(var p in Model.Profiles.Where(x=>x.Status!="Bản nháp").OrderByDescending(x=>x.SubmittedDate ?? x.CreatedDate)){
            <div class="review-card"><div class="row">
                <div class="col-lg-4"><strong>@(p.PartnerType=="Doanh nghiệp/Tổ chức" ? p.BusinessName : p.FullName)</strong><br/><span class="badge badge-info">@p.PartnerType</span> <span class="badge badge-secondary">@p.Status</span><br/><small>@p.Phone · @p.Email</small><br/><small>Gửi: @((p.SubmittedDate ?? p.CreatedDate).ToString("dd/MM/yyyy HH:mm"))</small></div>
                <div class="col-lg-5">
                    @if(p.PartnerType=="Doanh nghiệp/Tổ chức"){
                        <p class="mb-1"><strong>MST/ĐKKD:</strong> @p.TaxCode @p.BusinessRegistrationNumber<br/><strong>Trụ sở:</strong> @p.HeadquartersAddress<br/><strong>Đại diện:</strong> @p.LegalRepresentativeName<br/><strong>Ngân hàng:</strong> @p.BankName - @p.BankAccountNumber - @p.BankAccountHolder</p>
                    }else{
                        <p class="mb-1"><strong>CCCD:</strong> @p.CitizenIdentityNumber<br/><strong>Thường trú:</strong> @p.PermanentAddress<br/><strong>Hiện tại:</strong> @p.CurrentAddress<br/><strong>Ngân hàng:</strong> @p.BankName - @p.BankAccountNumber - @p.BankAccountHolder</p>
                    }
                    @if(!string.IsNullOrWhiteSpace(p.ReviewNote)){<div class="alert alert-light border mt-2 mb-0"><strong>Ghi chú:</strong> @p.ReviewNote</div>}
                </div>
                <div class="col-lg-3">
                    @if(p.Status!="Đã xác minh"){
                        <form method="post" action="/Admin/AdminVehiclePartner/ReviewProfile" class="staff-review-form">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@p.VehiclePartnerProfileID"/>
                            <div class="form-group"><label>Kết quả</label><select name="status" class="form-control" required><option value="" selected disabled>-- Chọn kết quả --</option><option>Đã xác minh</option><option>Yêu cầu bổ sung</option><option>Bị từ chối</option><option>Chờ xác minh lại</option></select></div>
                            <div class="form-group"><label>Lý do/ghi chú <span class="review-note-required text-danger d-none">*</span></label><textarea name="reviewNote" class="form-control" rows="3" maxlength="1000"></textarea></div>
                            <button class="btn btn-success btn-block">Lưu duyệt hồ sơ</button>
                        </form>
                    }else{<div class="alert alert-success mb-0">Đối tác đã xác minh và được phép gửi xe lên duyệt.</div>}
                </div>
            </div></div>
        }
        @if(!Model.Profiles.Any(x=>x.Status!="Bản nháp")){<div class="empty-state">Chưa có hồ sơ đối tác đã gửi duyệt.</div>}
    </div></div>

    <div class="card mb-4"><div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
            <div><h4 class="mb-1">Hồ sơ xe</h4><p class="text-muted mb-0">Danh sách chỉ hiển thị thông tin tóm tắt. Mở trang chi tiết để kiểm tra đủ giấy tờ, ảnh và giá trước khi quyết định.</p></div>
            <span class="badge badge-warning p-2">@Model.Applications.Count(x=>x.Status=="Chờ duyệt") chờ duyệt</span>
        </div>
        <div class="status-tabs mb-3">
            <a class="btn btn-sm @(string.IsNullOrWhiteSpace(selectedStatus)?"btn-primary":"btn-outline-primary")" href="/Admin/AdminVehiclePartner/Index">Tất cả</a>
            @foreach(var s in new[]{"Chờ duyệt","Yêu cầu bổ sung","Đã duyệt","Từ chối"}){<a class="btn btn-sm @(selectedStatus==s?"btn-primary":"btn-outline-primary")" asp-area="Admin" asp-controller="AdminVehiclePartner" asp-action="Index" asp-route-status="@s">@s</a>}
        </div>
        @foreach(var item in Model.Applications.OrderByDescending(x=>x.CreatedDate)){
            var imageCount = new[]{item.VehicleImageUrl,item.FrontImageUrl,item.RearImageUrl,item.LeftImageUrl,item.RightImageUrl,item.InteriorImageUrl,item.DashboardImageUrl}.Count(x=>!string.IsNullOrWhiteSpace(x));
            var documentCount = new[]{item.RegistrationImageUrl,item.InspectionImageUrl,item.InsuranceImageUrl}.Count(x=>!string.IsNullOrWhiteSpace(x));
            <div class="review-card"><div class="row align-items-center">
                <div class="col-md-3"><img src="@item.VehicleImageUrl" class="review-cover" alt="Ảnh đại diện @item.BrandName @item.Model"/></div>
                <div class="col-md-6 mt-3 mt-md-0">
                    <div class="d-flex flex-wrap align-items-center mb-2"><h5 class="mb-0 mr-2">@item.BrandName @item.Model @item.VehicleVersion</h5><span class="badge badge-secondary">@item.Status</span></div>
                    <div class="meta-grid">
                        <div class="meta-item"><strong>Biển số</strong>@item.LicensePlate</div>
                        <div class="meta-item"><strong>Chủ xe</strong>@item.OwnerFullName</div>
                        <div class="meta-item"><strong>Địa điểm</strong>@item.LocationName</div>
                        <div class="meta-item"><strong>Ngày gửi</strong>@item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
                        <div class="meta-item"><strong>Giá đề xuất</strong>@item.ProposedDailyPrice.ToString("#,0") VNĐ/ngày</div>
                        <div class="meta-item"><strong>Tiền cọc</strong>@item.ProposedDepositAmount.ToString("#,0") VNĐ</div>
                        <div class="meta-item"><strong>Hồ sơ</strong>@documentCount/3 giấy tờ · @imageCount/7 ảnh</div>
                        <div class="meta-item"><strong>Hình thức</strong>@item.RentalMode</div>
                    </div>
                </div>
                <div class="col-md-3 mt-3 mt-md-0 text-md-right">
                    @if(!string.IsNullOrWhiteSpace(item.AdminNote)){<div class="alert alert-light border text-left py-2"><small><strong>Ghi chú:</strong> @item.AdminNote</small></div>}
                    <a asp-area="Admin" asp-controller="AdminVehiclePartner" asp-action="VehicleApplication" asp-route-id="@item.VehiclePartnerApplicationID" class="btn btn-primary btn-block">Xem chi tiết hồ sơ</a>
                </div>
            </div></div>
        }
        @if(!Model.Applications.Any()){<div class="empty-state">Không có hồ sơ xe phù hợp.</div>}
    </div></div>

    <div class="card"><div class="card-body"><h4>Xe đối tác đang trên hệ thống</h4><div class="table-responsive"><table class="table table-bordered"><thead><tr><th>Xe</th><th>Địa điểm</th><th>Giá/ngày</th><th>Đặt cọc</th><th>Hoa hồng</th><th>Đơn hoàn thành</th><th>Doanh thu</th><th>Chủ xe nhận</th><th>Trạng thái</th></tr></thead><tbody>
        @foreach(var car in Model.Vehicles){<tr><td>@car.CarName<br/><small>@car.LicensePlate</small></td><td>@car.LocationName</td><td>@car.DailyPrice.ToString("#,0")</td><td>@car.DepositAmount.ToString("#,0")</td><td>@car.AppliedCommissionRate.ToString("0.##")%</td><td>@car.CompletedReservations</td><td>@car.GrossRevenue.ToString("#,0")</td><td>@car.OwnerNetRevenue.ToString("#,0")</td><td>@(car.IsActive?"Đang hoạt động":"Tạm ẩn")</td></tr>}
        @if(!Model.Vehicles.Any()){<tr><td colspan="9" class="text-center text-muted">Chưa có xe đối tác được duyệt.</td></tr>}
    </tbody></table></div></div></div>
</div></div>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const statusesRequiringReason = new Set(['Yêu cầu bổ sung', 'Bị từ chối', 'Từ chối']);
    document.querySelectorAll('.staff-review-form').forEach(function (form) {
        const status = form.querySelector('select[name="status"]');
        const note = form.querySelector('textarea[name="reviewNote"], textarea[name="adminNote"]');
        const requiredMark = form.querySelector('.review-note-required');
        if (!status || !note) return;
        function syncReasonRequirement(){const required=statusesRequiringReason.has(status.value);note.required=required;requiredMark?.classList.toggle('d-none',!required)}
        status.addEventListener('change',syncReasonRequirement);
        form.addEventListener('submit',function(event){syncReasonRequirement();if(!form.checkValidity()){event.preventDefault();form.reportValidity()}});
        syncReasonRequirement();
    });
});
</script>
