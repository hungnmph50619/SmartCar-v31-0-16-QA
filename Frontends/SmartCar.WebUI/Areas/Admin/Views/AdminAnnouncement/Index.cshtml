@model List<SmartCar.Dto.NotificationDtos.ResultCompanyAnnouncementDto>
@{ ViewData["Title"]="Thông báo công ty"; Layout="~/Views/AdminLayout/Index.cshtml"; }
<div class="page-content"><div class="container-fluid"><div class="row"><div class="col-xl-12"><div class="card"><div class="card-body">
<h4 class="card-title">Thông báo gửi tới người dùng</h4><p class="text-muted">Đăng thông báo cho nhân viên, khách hàng, chủ xe đối tác hoặc toàn hệ thống.</p>
@if(TempData["AnnouncementSuccess"]!=null){<div class="alert alert-success">@TempData["AnnouncementSuccess"]</div>}@if(TempData["AnnouncementError"]!=null){<div class="alert alert-danger">@TempData["AnnouncementError"]</div>}
<form method="post" action="/Admin/AdminAnnouncement/Create" class="border rounded p-3 mb-4">@Html.AntiForgeryToken()<div class="row"><div class="col-md-5 form-group"><label>Tiêu đề</label><input name="Title" class="form-control" required /></div><div class="col-md-3 form-group"><label>Người nhận</label><select name="AudienceRole" class="form-control"><option value="Staff">Nhân viên</option><option value="Customer">Khách hàng</option><option value="All">Tất cả</option></select></div><div class="col-md-2 form-group"><label>Ngày đăng</label><input name="PublishDate" type="date" value="@VietnamTime.Today.ToString("yyyy-MM-dd")" class="form-control" /></div><div class="col-md-2 form-group"><label>Hết hạn</label><input name="ExpiresDate" type="date" class="form-control" /></div></div>
<div class="form-group"><label>Nội dung</label><textarea name="Content" rows="3" class="form-control" required></textarea></div><label class="mr-3"><input type="checkbox" name="IsImportant" value="true" /> Quan trọng</label><input type="hidden" name="IsActive" value="true" /><button class="btn btn-primary">Đăng thông báo</button></form>
<div class="table-responsive"><table class="table table-bordered"><thead><tr><th>Thông báo</th><th>Người nhận</th><th>Thời gian</th><th></th></tr></thead><tbody>@foreach(var item in Model){<tr><td><strong>@item.Title</strong>@if(item.IsImportant){<span class="badge badge-danger ml-2">Quan trọng</span>}<br/><small>@item.Content</small></td><td>@item.AudienceRole</td><td>@item.PublishDate.ToString("dd/MM/yyyy")<br/><small>Hết hạn: @(item.ExpiresDate?.ToString("dd/MM/yyyy")??"Không")</small></td><td><form method="post" action="/Admin/AdminAnnouncement/Delete" onsubmit="return confirm('Xóa thông báo này?')">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.CompanyAnnouncementID"/><button class="btn btn-sm btn-danger">Xóa</button></form></td></tr>}</tbody></table></div>
</div></div></div></div></div></div>
