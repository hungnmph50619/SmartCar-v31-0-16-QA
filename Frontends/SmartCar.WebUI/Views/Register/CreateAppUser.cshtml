@model SmartCar.Dto.RegisterDtos.CreateRegisterDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng ký - SmartCar</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="Đăng ký tài khoản khách hàng SmartCar" />
    <meta name="author" content="Nhóm SD-46" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <link rel="shortcut icon" href="~/Admin/vertical/assets/images/favicon.ico" />
    <link href="~/Admin/vertical/assets/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <link href="~/Admin/vertical/assets/css/icons.min.css" rel="stylesheet" type="text/css" />
    <link href="~/Admin/vertical/assets/css/theme.min.css" rel="stylesheet" type="text/css" />
    <style>
        .validation-summary-valid{display:none}.auth-label{font-weight:600;color:#34495e}.password-toggle{min-width:64px}.caps-warning{display:none;font-size:.875rem;color:#b7791f;margin-top:.35rem}.policy-link{text-decoration:underline}
        @@media(max-width:575px){.auth-panel{padding:1.5rem!important}.min-vh-100{min-height:auto!important}}
    </style>
</head>
<body>
<div class="container">
    <div class="row">
        <div class="col-12">
            <div class="d-flex align-items-center min-vh-100">
                <div class="w-100 d-block bg-white shadow-lg rounded my-5">
                    <div class="row no-gutters">
                        <div class="col-lg-5 d-none d-lg-block bg-register rounded-left"></div>
                        <div class="col-lg-7">
                            <div class="p-5 auth-panel">
                                <div class="text-center mb-5">
                                    <a href="/Default/Index/" class="text-dark font-size-22 font-family-secondary" aria-label="Về trang chủ SmartCar">
                                        <i class="mdi mdi-car" aria-hidden="true"></i> <b>SmartCar</b>
                                    </a>
                                </div>
                                <div class="registration-progress mb-4" aria-label="Tiến trình đăng ký khách hàng">
                                    <div class="d-flex justify-content-between small font-weight-bold">
                                        <span class="text-success">Bước 1/3</span><span>Tạo tài khoản</span>
                                    </div>
                                    <div class="progress mt-2" style="height:7px"><div class="progress-bar bg-success" role="progressbar" style="width:33%" aria-valuenow="33" aria-valuemin="0" aria-valuemax="100"></div></div>
                                    <div class="d-flex justify-content-between text-muted mt-2" style="font-size:.75rem">
                                        <span>Tạo tài khoản</span><span>Xác minh email</span><span>Hoàn thiện hồ sơ</span>
                                    </div>
                                </div>
                                <h1 class="h4 mb-2">Tạo tài khoản khách thuê</h1>
                                <p class="text-muted mb-2">Bước này mất khoảng 2 phút. Sau khi tạo tài khoản, bạn sẽ xác minh email rồi hoàn thiện CCCD và giấy phép lái xe.</p>
                                <div class="alert alert-light border small mb-4"><strong>Bạn cần chuẩn bị sau bước này:</strong> email đang sử dụng, CCCD và giấy phép lái xe còn hiệu lực. Bạn vẫn có thể tìm xe trước khi hoàn thiện hồ sơ, nhưng phải đủ điều kiện xác minh trước khi nhận xe.</div>
                                <form class="user" method="post" asp-controller="Register" asp-action="CreateAppUser" id="registerForm">
                                    @Html.AntiForgeryToken()
                                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                                    <div class="form-group row">
                                        <div class="col-sm-6 mb-3 mb-sm-0">
                                            <label asp-for="Name" class="auth-label">Tên hiển thị</label>
                                            <input asp-for="Name" type="text" class="form-control form-control-user" autocomplete="given-name" />
                                            <span asp-validation-for="Name" class="text-danger"></span>
                                        </div>
                                        <div class="col-sm-6">
                                            <label asp-for="Surname" class="auth-label">Họ và tên đệm</label>
                                            <input asp-for="Surname" type="text" class="form-control form-control-user" autocomplete="family-name" />
                                            <span asp-validation-for="Surname" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="Email" class="auth-label">Địa chỉ email</label>
                                        <input asp-for="Email" type="email" class="form-control form-control-user" autocomplete="email" inputmode="email" />
                                        <span asp-validation-for="Email" class="text-danger"></span>
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="Phone" class="auth-label">Số điện thoại</label>
                                        <input asp-for="Phone" type="tel" class="form-control form-control-user" placeholder="Ví dụ: 0987654321" inputmode="tel" autocomplete="tel" />
                                        <span asp-validation-for="Phone" class="text-danger"></span>
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="Username" class="auth-label">Tên đăng nhập</label>
                                        <input asp-for="Username" type="text" class="form-control form-control-user" autocomplete="username" />
                                        <span asp-validation-for="Username" class="text-danger"></span>
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="Password" class="auth-label">Mật khẩu</label>
                                        <div class="input-group">
                                            <input asp-for="Password" type="password" class="form-control form-control-user" id="registerPassword" autocomplete="new-password" aria-describedby="passwordHelp capsWarning" />
                                            <div class="input-group-append"><button type="button" class="btn btn-outline-secondary password-toggle" data-password-toggle="registerPassword" aria-label="Hiện mật khẩu">Hiện</button></div>
                                        </div>
                                        <small id="passwordHelp" class="form-text text-muted">Tối thiểu 8 ký tự; nên có chữ hoa, chữ thường và số.</small>
                                        <div id="capsWarning" class="caps-warning" role="status">Caps Lock đang bật.</div>
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="ConfirmPassword" class="auth-label">Nhập lại mật khẩu</label>
                                        <div class="input-group">
                                            <input asp-for="ConfirmPassword" type="password" class="form-control form-control-user" id="confirmPassword" autocomplete="new-password" />
                                            <div class="input-group-append"><button type="button" class="btn btn-outline-secondary password-toggle" data-password-toggle="confirmPassword" aria-label="Hiện mật khẩu nhập lại">Hiện</button></div>
                                        </div>
                                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                    </div>
                                    <div class="form-group">
                                        <div class="custom-control custom-checkbox mb-2">
                                            <input asp-for="AgreeTerms" type="checkbox" class="custom-control-input" id="agreeTerms" />
                                            <label class="custom-control-label" for="agreeTerms">Tôi đã đọc và đồng ý với <a href="/Policy/OperatingRules" target="_blank" rel="noopener noreferrer" class="policy-link">Điều khoản sử dụng</a> của SmartCar.</label>
                                        </div>
                                        <span asp-validation-for="AgreeTerms" class="text-danger d-block"></span>
                                        <div class="custom-control custom-checkbox mt-2">
                                            <input asp-for="AgreePrivacy" type="checkbox" class="custom-control-input" id="agreePrivacy" />
                                            <label class="custom-control-label" for="agreePrivacy">Tôi đồng ý với <a href="/Policy/Privacy" target="_blank" rel="noopener noreferrer" class="policy-link">Chính sách bảo mật</a> và việc gửi OTP qua email.</label>
                                        </div>
                                        <span asp-validation-for="AgreePrivacy" class="text-danger d-block"></span>
                                    </div>
                                    <div class="alert alert-info small">OTP xác minh email có hiệu lực 5 phút. Bạn có thể gửi lại OTP nếu chưa nhận được hoặc mã đã hết hạn.</div>
                                    <button type="submit" class="btn btn-success btn-block waves-effect waves-light">Tạo tài khoản và gửi OTP</button>
                                </form>
                                <div class="row mt-4"><div class="col-12 text-center"><p class="text-muted mb-0">Đã có tài khoản? <a href="/Login/Index/" class="font-weight-medium"><b>Đăng nhập</b></a></p></div></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/Admin/vertical/assets/js/jquery.min.js"></script>
<script src="~/Admin/vertical/assets/js/bootstrap.bundle.min.js"></script>
<script src="~/Admin/vertical/assets/js/metismenu.min.js"></script>
<script src="~/Admin/vertical/assets/js/waves.js"></script>
<script src="~/Admin/vertical/assets/js/simplebar.min.js"></script>
<script src="~/Admin/vertical/assets/js/theme.js"></script>
<partial name="_ValidationScriptsPartial" />
<script>
(function(){
    document.querySelectorAll('[data-password-toggle]').forEach(function(button){
        button.addEventListener('click', function(){
            var input=document.getElementById(button.getAttribute('data-password-toggle'));
            var show=input.type==='password'; input.type=show?'text':'password';
            button.textContent=show?'Ẩn':'Hiện'; button.setAttribute('aria-label', show?'Ẩn mật khẩu':'Hiện mật khẩu');
        });
    });
    var password=document.getElementById('registerPassword'), warning=document.getElementById('capsWarning');
    password.addEventListener('keyup', function(e){ warning.style.display=e.getModifierState&&e.getModifierState('CapsLock')?'block':'none'; });
})();
</script>
</body>
</html>
