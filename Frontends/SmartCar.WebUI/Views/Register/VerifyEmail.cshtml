@model SmartCar.Dto.RegisterDtos.VerifyEmailOtpDto
@{
    Layout = null;
    var notice = TempData["RegisterMessage"]?.ToString();
    var emailSent = TempData["RegisterEmailSent"]?.ToString() == "true";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Xác minh email - Smart Car</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link rel="shortcut icon" href="~/Admin/vertical/assets/images/favicon.ico">
    <link href="~/Admin/vertical/assets/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <link href="~/Admin/vertical/assets/css/icons.min.css" rel="stylesheet" type="text/css" />
    <link href="~/Admin/vertical/assets/css/theme.min.css" rel="stylesheet" type="text/css" />
</head>
<body>
<div class="container">
    <div class="row justify-content-center align-items-center min-vh-100">
        <div class="col-lg-6">
            <div class="card shadow-lg border-0 rounded">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <a href="/Default/Index/" class="text-dark font-size-22 font-family-secondary"><b>Smart Car</b></a>
                    </div>
                    <h1 class="h5 mb-2">Xác minh email đăng ký</h1>
                    <p class="text-muted">Nhập mã OTP 6 chữ số đã gửi tới email của bạn. Mã có hiệu lực trong <b>5 phút</b> và chỉ dùng một lần.</p>
                    @if (!string.IsNullOrWhiteSpace(notice))
                    {
                        <div class="alert @(emailSent ? "alert-success" : "alert-warning")">@notice</div>
                    }
                    @if (TempData["VerifyEmailSuccess"] != null)
                    {
                        <div class="alert alert-success">@TempData["VerifyEmailSuccess"]</div>
                    }
                    @if (TempData["VerifyEmailError"] != null)
                    {
                        <div class="alert alert-danger">@TempData["VerifyEmailError"]</div>
                    }
                    <form method="post" asp-action="VerifyEmail">
                        @Html.AntiForgeryToken()
                        <input asp-for="RegistrationAttemptId" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <div class="form-group">
                            <label>Tên đăng nhập</label>
                            <input asp-for="Username" class="form-control" readonly />
                            <span asp-validation-for="Username" class="text-danger"></span>
                            <small class="text-muted">Hệ thống dùng tên đăng nhập để xác minh đúng tài khoản, vì nhiều tài khoản có thể dùng chung một email.</small>
                        </div>
                        <div class="form-group">
                            <label>Email nhận OTP</label>
                            <input asp-for="Email" type="email" class="form-control" readonly />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label>Mã OTP</label>
                            <input asp-for="Otp" class="form-control text-center" inputmode="numeric" maxlength="6" placeholder="______" style="font-size:26px;letter-spacing:10px;font-weight:700" />
                            <span asp-validation-for="Otp" class="text-danger"></span>
                        </div>
                        <button class="btn btn-success btn-block waves-effect waves-light">Xác minh email</button>
                    </form>
                    <div class="alert alert-info small mt-3 mb-2">
                        Nếu OTP hết hạn hoặc bạn chưa nhận được email, hãy bấm <b>Gửi lại OTP</b>.
                        Mã OTP mới cũng chỉ có hiệu lực <b>5 phút</b>. Để tránh gửi quá nhiều email, hệ thống chỉ cho gửi lại sau mỗi <b>60 giây</b>.
                    </div>
                    <form method="post" asp-action="ResendEmailOtp" class="mt-2" id="resendOtpForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="registrationAttemptId" value="@Model.RegistrationAttemptId" />
                        <input type="hidden" name="username" value="@Model.Username" />
                        <input type="hidden" name="email" value="@Model.Email" />
                        <button type="submit" class="btn btn-outline-primary btn-block" id="resendOtpButton">Gửi lại OTP</button>
                    </form>
                    <div class="text-center mt-4">
                        <a href="/Login/Index" class="text-muted">Quay lại đăng nhập</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/Admin/vertical/assets/js/jquery.min.js"></script>
<script src="~/Admin/vertical/assets/js/bootstrap.bundle.min.js"></script>
<script src="~/Admin/vertical/assets/js/theme.js"></script>
<script>
    // UX demo: sau khi bấm gửi lại, khóa nút 60 giây ở phía giao diện.
    // Server vẫn kiểm tra lại 60 giây nên người dùng refresh trang cũng không spam OTP được.
    const resendForm = document.getElementById('resendOtpForm');
    const resendButton = document.getElementById('resendOtpButton');
    if (resendForm && resendButton) {
        resendForm.addEventListener('submit', function () {
            let seconds = 60;
            resendButton.disabled = true;
            resendButton.innerText = `Đã gửi, chờ ${seconds}s để gửi lại`;
            const timer = setInterval(function () {
                seconds--;
                resendButton.innerText = `Đã gửi, chờ ${seconds}s để gửi lại`;
                if (seconds <= 0) {
                    clearInterval(timer);
                    resendButton.disabled = false;
                    resendButton.innerText = 'Gửi lại OTP';
                }
            }, 1000);
        });
    }
</script>
</body>
</html>
