@model StaffVerificationReviewDto
@{
    ViewData["Title"]="Duyệt hồ sơ khách";
    Layout="~/Views/AdminLayout/Index.cshtml";
}
<div class="page-content"><div class="container-fluid" style="max-width:1200px">
    @if(TempData["StaffError"]!=null){<div class="alert alert-danger">@TempData["StaffError"]</div>}
    <div class="d-flex justify-content-between align-items-center mb-4"><div><h2>Duyệt hồ sơ khách thuê</h2><p class="text-muted mb-0">Chỉ đối chiếu và kết luận; không được sửa dữ liệu người dùng.</p></div><a href="/StaffDashboard/Index" class="btn btn-outline-secondary">Quay lại hàng đợi</a></div>
    <div class="row"><div class="col-lg-4"><div class="card border-0 shadow-sm mb-4"><div class="card-body"><h4>@Model.LegalFullName</h4><p class="text-muted mb-2">Tên hiển thị tài khoản: @Model.FullName</p><p>@Model.Email<br/>@Model.Phone</p><hr/><p><strong>Giới tính:</strong> @(string.IsNullOrWhiteSpace(Model.Gender)?"Thiếu":Model.Gender)</p><p><strong>CCCD:</strong> @Model.CitizenIdMasked</p><p><strong>Ngày sinh:</strong> @(Model.DateOfBirth?.ToString("dd/MM/yyyy")??"Thiếu")</p><p><strong>Ngày cấp CCCD:</strong> @(Model.CitizenIdIssuedDate?.ToString("dd/MM/yyyy")??"Thiếu")</p><p><strong>Hết hạn CCCD:</strong> @(Model.CitizenIdExpiryDate?.ToString("dd/MM/yyyy")??"Thiếu")</p><p><strong>Địa chỉ theo giấy tờ:</strong> @(string.IsNullOrWhiteSpace(Model.CitizenIdAddress)?"Thiếu":Model.CitizenIdAddress)</p><p><strong>Thường trú hiện hành:</strong> @(string.IsNullOrWhiteSpace(Model.PermanentAddress)?"Thiếu":Model.PermanentAddress)</p><p><strong>Hiện tại:</strong> @(string.IsNullOrWhiteSpace(Model.CurrentAddress)?"Thiếu":Model.CurrentAddress)</p>@if(Model.CurrentAddressSameAsPermanent){<p class="text-success"><strong>Ghi chú:</strong> Khách tích địa chỉ hiện tại giống thường trú.</p>}<hr/><p><strong>Số GPLX:</strong> @(string.IsNullOrWhiteSpace(Model.DriverLicenseNumber)?"Thiếu":Model.DriverLicenseNumber)</p><p><strong>Hạng GPLX:</strong> @(string.IsNullOrWhiteSpace(Model.DriverLicenseClass)?"Thiếu":Model.DriverLicenseClass)</p><p><strong>Ngày cấp bằng:</strong> @(Model.DriverLicenseIssuedDate?.ToString("dd/MM/yyyy")??"Thiếu")</p><p><strong>Hết hạn bằng:</strong> @(Model.DriverLicenseExpiry?.ToString("dd/MM/yyyy")??"Thiếu")</p><span class="badge badge-warning">@Model.Status</span></div></div>
        <div class="card border-0 shadow-sm"><div class="card-body"><h5>Kết luận hồ sơ</h5><form asp-action="ReviewVerification" method="post" id="verificationReviewForm">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.UserVerificationID"/><div class="form-group"><label>Lý do/yêu cầu bổ sung</label><textarea name="reason" id="reviewReason" class="form-control" rows="4" placeholder="Nêu rõ thông tin hoặc ảnh khách cần bổ sung" aria-describedby="reviewReasonError"></textarea><div id="reviewReasonError" class="text-danger mt-1" role="alert" style="display:none">Hãy nhập lý do để khách hàng biết cần sửa gì.</div></div><button name="status" value="Đã xác minh" class="btn btn-success btn-block" onclick="return confirm('Xác nhận giấy tờ hợp lệ và còn hạn?')">Chấp nhận</button><button name="status" value="Yêu cầu bổ sung" class="btn btn-warning btn-block" data-needs-reason="true">Yêu cầu bổ sung</button><button name="status" value="Bị từ chối" class="btn btn-outline-danger btn-block" data-needs-reason="true">Từ chối</button></form></div></div>
    </div><div class="col-lg-8"><div class="row">
        <div class="col-md-6 mb-4"><div class="doc-card"><h5>CCCD mặt trước</h5><a href="@Model.CitizenIdFrontUrl" target="_blank" rel="noopener noreferrer"><img src="@Model.CitizenIdFrontUrl" alt="Ảnh CCCD mặt trước"/></a></div></div>
        <div class="col-md-6 mb-4"><div class="doc-card"><h5>CCCD mặt sau</h5><a href="@Model.CitizenIdBackUrl" target="_blank" rel="noopener noreferrer"><img src="@Model.CitizenIdBackUrl" alt="Ảnh CCCD mặt sau"/></a></div></div>
        <div class="col-md-6 mb-4"><div class="doc-card"><h5>Bằng lái xe</h5><a href="@Model.DriverLicenseUrl" target="_blank" rel="noopener noreferrer"><img src="@Model.DriverLicenseUrl" alt="Ảnh giấy phép lái xe"/></a></div></div>
        <div class="col-md-6 mb-4"><div class="doc-card"><h5>Ảnh chân dung</h5><a href="@Model.PortraitUrl" target="_blank" rel="noopener noreferrer"><img src="@Model.PortraitUrl" alt="Ảnh chân dung khách hàng"/></a></div></div>
    </div><div class="alert alert-info"><strong>Kiểm tra:</strong> ảnh rõ nét, thông tin họ tên/ngày sinh thống nhất, bằng lái đúng hạng và còn hạn, chân dung phù hợp. Khi sai, trả hồ sơ để khách tự sửa và gửi lại.</div></div></div>
</div></div>
<style>.doc-card{background:#fff;border-radius:14px;padding:18px;box-shadow:0 8px 25px rgba(30,50,70,.08);height:100%}.doc-card img{width:100%;height:270px;object-fit:contain;background:#f4f6f8;border-radius:8px}.badge{padding:.6rem .8rem}</style>

<script>
(function(){var form=document.getElementById('verificationReviewForm'),reason=document.getElementById('reviewReason'),error=document.getElementById('reviewReasonError');if(!form)return;form.addEventListener('submit',function(e){var button=e.submitter;if(button&&button.getAttribute('data-needs-reason')==='true'&&!reason.value.trim()){e.preventDefault();error.style.display='block';reason.focus();}else{error.style.display='none';}});})();
</script>
