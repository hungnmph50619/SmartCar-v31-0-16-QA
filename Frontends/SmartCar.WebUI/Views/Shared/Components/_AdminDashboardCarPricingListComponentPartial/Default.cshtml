@model List<ResultCarPricingListWithModelDto>

<div class="col-xl-6">

    <div class="card">
        <div class="card-body">

            <h4 class="card-title">Giá thuê xe</h4>
            <p class="card-subtitle mb-4 font-size-13">
                Giá thuê theo ngày, tuần và tháng của một số xe.
            </p>

            <div class="table-responsive">
                <table class="table table-centered table-hover table-xl mb-0" id="recent-orders">
                    <thead>
                        <tr>
                            <th class="border-top-0">Hãng xe</th>
                            <th class="border-top-0">Model</th>
                            <th class="border-top-0">Giá theo ngày</th>
                            <th class="border-top-0">Giá theo tuần</th>
                            <th class="border-top-0">Giá theo tháng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var item in Model)
                        {
                            <tr>
                                <td class="text-truncate">@item.Brand</td>
                                <td class="text-truncate">@item.model</td>                      
                                <td class="text-truncate">VNĐ @item.dailyAmount</td>
                                <td class="text-truncate">VNĐ @item.weeklyAmount</td>
                                <td class="text-truncate">VNĐ @item.monthlyAmount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>