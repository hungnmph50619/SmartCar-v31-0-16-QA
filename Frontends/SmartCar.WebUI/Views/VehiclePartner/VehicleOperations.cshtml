@model PartnerVehicleOperationsDto
@{
    ViewData["Title"] = $"Vận hành {Model.Vehicle.CarName}";
    Layout = "~/Views/UILayout/Partner.cshtml";
    string StatusClass(string status) => status switch { "Đang hoạt động" or "Đã xác minh" or "Hoàn thành" => "success", "Tạm khóa" or "Bị từ chối" => "danger", "Đang bảo dưỡng" or "Chờ duyệt" => "warning", _ => "info" };
}
<section class="ftco-section bg-light py-5"><div class="container" style="max-width:1220px">
@if(TempData["VehiclePartnerSuccess"]!=null){<div class="alert alert-success">@TempData["VehiclePartnerSuccess"]</div>}
@if(TempData["VehiclePartnerError"]!=null){<div class="alert alert-danger">@TempData["VehiclePartnerError"]</div>}
<div id="overview" class="d-flex flex-wrap justify-content-between align-items-center mb-4 section-anchor"><div><a href="/VehiclePartner/Dashboard#vehicles">← Xe của tôi</a><h2 class="mt-2 mb-1">@Model.Vehicle.CarName</h2><p class="text-muted mb-0">@Model.Vehicle.LicensePlate · @Model.Vehicle.LocationName</p></div><div class="d-flex align-items-center mt-3 mt-md-0"><a href="/VehiclePartner/VehicleDetails/@Model.Vehicle.PartnerVehicleID" class="btn btn-outline-primary mr-2">Xem thông tin xe</a><span class="badge badge-@StatusClass(Model.Vehicle.OperationalStatus) p-3">@Model.Vehicle.OperationalStatus</span></div></div>
@if(!string.IsNullOrWhiteSpace(Model.Vehicle.WarningText)){<div class="alert alert-warning"><strong>Cảnh báo vận hành:</strong> @Model.Vehicle.WarningText</div>}
<div class="row mb-4"><div class="col-lg-3 col-6 mb-3"><div class="op-kpi"><small>Lịch sắp tới</small><strong>@Model.UpcomingReservationCount</strong></div></div><div class="col-lg-3 col-6 mb-3"><div class="op-kpi"><small>Đơn đang thuê</small><strong>@Model.ActiveReservationCount</strong></div></div><div class="col-lg-3 col-6 mb-3"><div class="op-kpi"><small>Doanh thu gộp</small><strong>@Model.Vehicle.GrossRevenue.ToString("#,0", CultureInfo.InvariantCulture) đ</strong></div></div><div class="col-lg-3 col-6 mb-3"><div class="op-kpi"><small>Chủ xe thực nhận</small><strong>@Model.Vehicle.OwnerNetRevenue.ToString("#,0", CultureInfo.InvariantCulture) đ</strong></div></div></div>
<div class="operation-tabs mb-4"><a href="#schedule" class="btn btn-outline-primary">Lịch thuê</a><a href="#documents" class="btn btn-outline-primary">Giấy tờ</a><a href="#maintenance" class="btn btn-outline-primary">Bảo dưỡng</a><a href="#availability" class="btn btn-outline-primary">Trạng thái khai thác</a></div>
<div class="row"><div class="col-lg-8">
<div id="schedule" class="card border-0 shadow-sm mb-4 section-anchor"><div class="card-body p-4"><h4>Lịch thuê và trạng thái đơn</h4>@if(Model.Calendar.Count==0){<div class="alert alert-light border mb-0">Chưa có lịch thuê.</div>}else{<div class="table-responsive"><table class="table"><thead><tr><th>Đơn</th><th>Khách</th><th>Thời gian</th><th>Trạng thái</th><th>Thực nhận</th><th></th></tr></thead><tbody>@foreach(var item in Model.Calendar){<tr><td>#@item.ReservationID</td><td>@item.CustomerName</td><td>@item.Start.ToString("dd/MM HH:mm")<br/>→ @item.End.ToString("dd/MM HH:mm")</td><td><span class="badge badge-@StatusClass(item.Status)">@item.Status</span></td><td>@item.OwnerReceivableAmount.ToString("#,0", CultureInfo.InvariantCulture) đ</td><td><a href="/ReservationLookup/Details/@item.ReservationID" class="btn btn-sm btn-outline-primary">Chi tiết</a></td></tr>}</tbody></table></div>}</div></div>
<div id="documents" class="card border-0 shadow-sm mb-4 section-anchor"><div class="card-body p-4"><div class="d-flex flex-wrap justify-content-between align-items-center mb-3"><div><h4>Giấy tờ xe</h4><p class="text-muted mb-0">Giấy tờ hết hạn làm xe tự động bị ẩn khỏi kết quả tìm kiếm.</p></div><button type="button" class="btn btn-outline-primary toggle-form" data-target="documentForm">+ Gửi giấy tờ mới</button></div><div class="row">@foreach(var doc in Model.Documents){<div class="col-md-6 mb-3"><div class="op-item"><div class="d-flex justify-content-between"><strong>@doc.DocumentType</strong><span class="badge badge-@StatusClass(doc.Status)">@doc.Status</span></div><div>Số: @doc.DocumentNumber</div><small>Cấp: @(doc.IssuedDate?.ToString("dd/MM/yyyy")??"—") · Hết hạn: @(doc.ExpiryDate?.ToString("dd/MM/yyyy")??"Không thời hạn")</small>@if(!string.IsNullOrWhiteSpace(doc.RejectionReason)){<div class="text-danger mt-1">@doc.RejectionReason</div>}<br/><a href="@doc.FileUrl" target="_blank">Xem tệp</a></div></div>}</div><form id="documentForm" asp-action="AddVehicleDocument" method="post" enctype="multipart/form-data" class="op-form collapsible-form" hidden>@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Vehicle.PartnerVehicleID"/><h5>Gửi giấy tờ mới/gia hạn</h5><div class="row"><div class="col-md-3 form-group"><label>Loại giấy tờ</label><select name="documentType" class="form-control"><option>Đăng ký xe</option><option>Đăng kiểm</option><option>Bảo hiểm</option><option>Ủy quyền</option></select></div><div class="col-md-3 form-group"><label>Số giấy tờ</label><input name="documentNumber" class="form-control" required/></div><div class="col-md-3 form-group"><label>Ngày cấp</label><input name="issuedDate" type="date" class="form-control"/></div><div class="col-md-3 form-group"><label>Ngày hết hạn</label><input name="expiryDate" type="date" class="form-control"/></div></div><div class="form-group"><label>Ảnh giấy tờ</label><input name="documentFile" type="file" accept="image/*,.pdf" class="form-control-file" required/></div><button class="btn btn-primary">Gửi để nhân viên duyệt</button></form></div></div>
<div id="maintenance" class="card border-0 shadow-sm mb-4 section-anchor"><div class="card-body p-4"><div class="d-flex flex-wrap justify-content-between align-items-center mb-3"><h4>Lịch sử và kế hoạch bảo dưỡng</h4><button type="button" class="btn btn-outline-primary toggle-form" data-target="maintenanceForm">+ Ghi nhận bảo dưỡng</button></div>@if(!Model.MaintenanceRecords.Any()){<div class="alert alert-light border">Chưa có lịch sử bảo dưỡng.</div>}@foreach(var m in Model.MaintenanceRecords){<div class="op-item mb-2"><div class="d-flex justify-content-between"><strong>@m.MaintenanceDate.ToString("dd/MM/yyyy") · @m.OdometerKm.ToString("#,0", CultureInfo.InvariantCulture) km</strong>@if(m.HasUnresolvedSafetyIssue){<span class="badge badge-danger">Còn lỗi an toàn</span>}</div><div>@m.WorkPerformed</div><small>@m.Garage · @m.Cost.ToString("#,0", CultureInfo.InvariantCulture) đ · Lần tới: @(m.NextMaintenanceDate?.ToString("dd/MM/yyyy")??"Chưa đặt") / @(m.NextMaintenanceKm?.ToString("#,0", CultureInfo.InvariantCulture)??"—") km</small>@if(!string.IsNullOrWhiteSpace(m.SafetyIssueNote)){<div class="text-danger">@m.SafetyIssueNote</div>}</div>}<form id="maintenanceForm" asp-action="AddMaintenance" method="post" class="op-form mt-3 collapsible-form" hidden>@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Vehicle.PartnerVehicleID"/><h5>Ghi nhận bảo dưỡng</h5><div class="row"><div class="col-md-4 form-group"><label>Ngày bảo dưỡng</label><input name="maintenanceDate" type="date" value="@VietnamTime.Today.ToString("yyyy-MM-dd")" class="form-control" required/></div><div class="col-md-4 form-group"><label>Số kilomet hiện tại</label><input name="odometerKm" type="number" min="0" class="form-control" required/></div><div class="col-md-4 form-group"><label>Chi phí</label><input name="cost" type="number" min="0" class="form-control" required/></div></div><div class="form-group"><label>Nội dung thực hiện</label><textarea name="workPerformed" class="form-control" required></textarea></div><div class="row"><div class="col-md-4 form-group"><label>Garage</label><input name="garage" class="form-control"/></div><div class="col-md-4 form-group"><label>Ngày bảo dưỡng tiếp</label><input name="nextMaintenanceDate" type="date" class="form-control"/></div><div class="col-md-4 form-group"><label>Km bảo dưỡng tiếp</label><input name="nextMaintenanceKm" type="number" min="0" class="form-control"/></div></div><label><input type="checkbox" name="hasUnresolvedSafetyIssue" value="true"/> Còn vấn đề an toàn chưa xử lý</label><textarea name="safetyIssueNote" class="form-control mt-2" placeholder="Mô tả để hệ thống tạm khóa xe khi cần"></textarea><button class="btn btn-primary mt-3">Lưu bảo dưỡng</button></form></div></div>
</div>
<div class="col-lg-4"><div class="card border-0 shadow-sm mb-4 sticky-top" style="top:90px"><div class="card-body p-4"><h4>Thông số vận hành</h4><div class="op-line"><span>Giới hạn</span><strong>@Model.KmLimitPerDay km/ngày</strong></div><div class="op-line"><span>Phí vượt</span><strong>@Model.ExtraKmFee.ToString("#,0", CultureInfo.InvariantCulture) đ/km</strong></div><div class="op-line"><span>Hoa hồng</span><strong>@Model.Vehicle.AppliedCommissionRate.ToString("0.##")%</strong></div><hr/><div id="availability" class="section-anchor"><h5>Trạng thái khai thác</h5><p class="text-muted small">Bạn có thể tự bật hoặc tắt nhận đơn. Khi bật lại, xe hoạt động ngay nếu giấy tờ còn hạn và không có cảnh báo an toàn.</p><form asp-action="UpdateAvailability" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Vehicle.PartnerVehicleID"/><input type="hidden" name="isActive" value="@(!Model.Vehicle.IsActive)"/>@if(Model.Vehicle.IsActive){<div class="form-group"><label>Lý do tạm dừng</label><textarea name="reason" class="form-control" rows="3" required>@Model.PauseReason</textarea></div>}else{<input type="hidden" name="reason" value=""/>}<button class="btn @(Model.Vehicle.IsActive?"btn-outline-danger":"btn-success") btn-block" data-confirm="@(Model.Vehicle.IsActive ? "Xác nhận ngừng nhận đơn mới cho xe này?" : "Bật nhận đơn mới cho xe này ngay bây giờ?")">@(Model.Vehicle.IsActive?"Ngừng nhận đơn mới":"Bật nhận đơn mới")</button></form></div></div></div></div>
</div></div></section>
<style>
.section-anchor{scroll-margin-top:95px}.operation-tabs{display:flex;gap:8px;flex-wrap:wrap}.operation-tabs .btn{border-radius:20px}.op-kpi,.op-item,.op-form{background:#fff;border:1px solid #e5ebf1;border-radius:13px;padding:17px}.op-kpi{height:100%;display:flex;flex-direction:column}.op-kpi small{color:#718096}.op-kpi strong{font-size:21px}.op-item{background:#f8fafc}.op-form{background:#f7fbff;border-color:#cfe8ff}.op-line{display:flex;justify-content:space-between;gap:12px;padding:10px 0;border-bottom:1px dashed #dce4eb}.table td{vertical-align:middle}.collapsible-form{margin-top:16px}
</style>
<script>
(function(){
document.querySelectorAll('.toggle-form').forEach(function(button){button.addEventListener('click',function(){var form=document.getElementById(button.getAttribute('data-target'));if(!form)return;form.hidden=!form.hidden;button.textContent=form.hidden?(button.getAttribute('data-target')==='maintenanceForm'?'+ Ghi nhận bảo dưỡng':'+ Gửi giấy tờ mới'):'Đóng biểu mẫu';if(!form.hidden)form.scrollIntoView({behavior:'smooth',block:'nearest'});});});
document.querySelectorAll('[data-confirm]').forEach(function(button){button.addEventListener('click',function(event){if(!window.confirm(button.getAttribute('data-confirm')))event.preventDefault();});});
})();
</script>