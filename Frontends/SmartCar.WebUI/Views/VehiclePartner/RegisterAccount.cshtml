@model SmartCar.Dto.MarketplaceDtos.CreateVehiclePartnerAccountDto
@{
    ViewData["Title"] = "Đăng ký tài khoản đối tác chủ xe";
    Layout = null;
}
<!DOCTYPE html><html lang="vi"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/><title>Đăng ký đối tác chủ xe - SmartCar</title><link href="~/Admin/vertical/assets/css/bootstrap.min.css" rel="stylesheet"/><link href="~/Admin/vertical/assets/css/theme.min.css" rel="stylesheet"/></head><body class="partner-register-bg">
<div class="container py-5"><div class="register-shell"><div class="register-side"><a href="/Default/Index" class="brand">SMART<span>CAR</span></a><h2>Tạo tài khoản đối tác chủ xe</h2><p>Tài khoản này chỉ dùng để đăng xe, xử lý yêu cầu thuê, giao nhận xe và theo dõi đối soát.</p><ul><li>Đăng ký tài khoản ngắn gọn</li><li>Xác minh email bằng OTP</li><li>Hoàn thiện hồ sơ đối tác sau khi đăng nhập</li><li>Chỉ đối tác đã xác minh mới được gửi xe lên duyệt</li></ul><a href="/VehiclePartner/BecomeOwner" class="btn btn-outline-light">Tìm hiểu chương trình</a></div><div class="register-form"><h3>Thông tin tài khoản đối tác</h3><p class="text-muted">Form này chỉ tạo tài khoản đăng nhập và kênh liên lạc ban đầu. CCCD, giấy tờ pháp lý và ngân hàng sẽ nhập ở bước xác minh hồ sơ sau khi xác minh email.</p><form method="post" asp-action="RegisterAccount">@Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
<div class="form-row"><div class="form-group col-md-6"><label>Tên đăng nhập *</label><input asp-for="Username" class="form-control" autocomplete="username"/><span asp-validation-for="Username" class="text-danger"></span></div><div class="form-group col-md-6"><label>Loại đối tác *</label><select asp-for="PartnerType" class="form-control"><option>Cá nhân</option><option>Doanh nghiệp/Tổ chức</option></select><span asp-validation-for="PartnerType" class="text-danger"></span></div></div>
<div class="form-row"><div class="form-group col-md-6"><label>Email *</label><input asp-for="Email" type="email" class="form-control" autocomplete="email" inputmode="email"/><span asp-validation-for="Email" class="text-danger"></span><small class="text-muted">Dùng để nhận OTP, thông báo hồ sơ và khôi phục mật khẩu.</small></div><div class="form-group col-md-6"><label>Số điện thoại *</label><input asp-for="Phone" class="form-control" placeholder="09xxxxxxxx" autocomplete="tel" inputmode="tel"/><span asp-validation-for="Phone" class="text-danger"></span><small class="text-muted">Dùng để liên hệ khi có đơn thuê, giao nhận xe hoặc sự cố.</small></div></div>
<div class="form-row"><div class="form-group col-md-6"><label>Mật khẩu *</label><div class="input-group"><input asp-for="Password" id="partnerPassword" type="password" class="form-control" autocomplete="new-password"/><div class="input-group-append"><button type="button" class="btn btn-outline-secondary" data-password-toggle="partnerPassword">Hiện</button></div></div><span asp-validation-for="Password" class="text-danger"></span></div><div class="form-group col-md-6"><label>Xác nhận mật khẩu *</label><div class="input-group"><input asp-for="ConfirmPassword" id="partnerConfirmPassword" type="password" class="form-control" autocomplete="new-password"/><div class="input-group-append"><button type="button" class="btn btn-outline-secondary" data-password-toggle="partnerConfirmPassword">Hiện</button></div></div><span asp-validation-for="ConfirmPassword" class="text-danger"></span></div></div>
<div class="alert alert-light border"><strong>Loại đối tác dùng để làm gì?</strong><br/>Nếu chọn <b>Cá nhân</b>, hệ thống yêu cầu CCCD, ảnh chân dung và tài khoản ngân hàng cá nhân ở bước xác minh. Nếu chọn <b>Doanh nghiệp/Tổ chức</b>, hệ thống yêu cầu thêm thông tin pháp lý, người đại diện, giấy đăng ký và tài khoản nhận đối soát.</div>
<div class="custom-control custom-checkbox mb-2"><input asp-for="AgreePartnerTerms" type="checkbox" class="custom-control-input" id="agreeTerms"/><label class="custom-control-label" for="agreeTerms">Tôi đã đọc và đồng ý với <a href="/Policy/OperatingRules" target="_blank" rel="noopener noreferrer"><u>Điều khoản đối tác</u></a> của SmartCar.</label><span asp-validation-for="AgreePartnerTerms" class="text-danger d-block"></span></div>
<div class="custom-control custom-checkbox mb-4"><input asp-for="AgreePrivacyPolicy" type="checkbox" class="custom-control-input" id="agreePrivacy"/><label class="custom-control-label" for="agreePrivacy">Tôi đã đọc và đồng ý với <a href="/Policy/Privacy" target="_blank" rel="noopener noreferrer"><u>Chính sách bảo mật</u></a> của SmartCar.</label><span asp-validation-for="AgreePrivacyPolicy" class="text-danger d-block"></span></div>
<button class="btn btn-success btn-block py-3">Tạo tài khoản và gửi OTP</button><p class="text-center mt-3 mb-0">Đã có tài khoản? <a href="/Login/Index">Đăng nhập</a></p></form></div></div></div>
<style>.partner-register-bg{background:#eef3f7}.register-shell{display:grid;grid-template-columns:.8fr 1.7fr;background:#fff;border-radius:22px;overflow:hidden;box-shadow:0 18px 60px rgba(20,45,70,.14)}.register-side{padding:50px;background:linear-gradient(145deg,#102a43,#168cf2);color:#fff}.brand{font-size:25px;font-weight:900;color:#fff}.brand span{color:#01d28e}.register-side h2{font-size:36px;margin:65px 0 20px}.register-side li{margin-bottom:12px}.register-form{padding:45px 50px}.register-form h3{color:#172b3a}@@media(max-width:991px){.register-shell{grid-template-columns:1fr}.register-side h2{margin:30px 0 15px}.register-form,.register-side{padding:30px}}</style>
<script src="~/Admin/vertical/assets/js/jquery.min.js"></script><script src="~/Admin/vertical/assets/js/bootstrap.bundle.min.js"></script><partial name="_ValidationScriptsPartial" /><script>(function(){document.querySelectorAll('[data-password-toggle]').forEach(function(button){button.addEventListener('click',function(){var input=document.getElementById(button.getAttribute('data-password-toggle')),show=input.type==='password';input.type=show?'text':'password';button.textContent=show?'Ẩn':'Hiện';button.setAttribute('aria-label',show?'Ẩn mật khẩu':'Hiện mật khẩu');});});})();</script></body></html>
