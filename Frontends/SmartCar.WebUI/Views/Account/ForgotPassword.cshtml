@model SmartCar.Dto.AccountDtos.ForgotPasswordDto
@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Quên mật khẩu - Smart Car</title>
    <link href="~/Admin/vertical/assets/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Admin/vertical/assets/css/theme.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
<div class="container"><div class="row justify-content-center"><div class="col-md-6 col-lg-5">
<div class="card shadow border-0 my-5"><div class="card-body p-5">
    <a href="/Login/Index" class="text-muted">← Quay lại đăng nhập</a>
    <h2 class="mt-4">Quên mật khẩu</h2>
    <p class="text-muted">Nhập tên đăng nhập và email nhận OTP/khôi phục của tài khoản. Vì nhiều tài khoản có thể dùng chung email, hệ thống cần tên đăng nhập để xác định đúng tài khoản.</p>
    @if (ViewBag.Message != null) { <div class="alert alert-info">@ViewBag.Message</div> }
    @if (ViewBag.DevelopmentResetUrl != null) { <div class="alert alert-warning"><strong>Chế độ phát triển:</strong> Gmail chưa cấu hình. <a href="@ViewBag.DevelopmentResetUrl">Mở liên kết đặt lại mật khẩu</a>.</div> }
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <form method="post">@Html.AntiForgeryToken()
        <div class="form-group"><label asp-for="Username">Tên đăng nhập</label><input asp-for="Username" class="form-control" placeholder="ten_dang_nhap" autocomplete="username" /><span asp-validation-for="Username" class="text-danger"></span></div>
        <div class="form-group"><label asp-for="Email">Email nhận liên kết</label><input asp-for="Email" type="email" class="form-control" placeholder="email@gmail.com" autocomplete="email" inputmode="email" /><span asp-validation-for="Email" class="text-danger"></span></div>
        <button class="btn btn-primary btn-block">Gửi liên kết đặt lại</button>
    </form>
</div></div></div></div></div>
<script src="~/Admin/vertical/assets/js/jquery.min.js"></script><partial name="_ValidationScriptsPartial" /></body></html>
