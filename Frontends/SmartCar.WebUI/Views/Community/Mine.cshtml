@model SmartCar.WebUI.Models.CommunityMineViewModel
@{ Layout = "~/Views/UILayout/Index.cshtml"; ViewData["Title"]="Bài của tôi"; }
<style>.mine-head{padding:120px 0 40px;background:#eef6ff}.mine-wrap{padding:40px 0;background:#f7f9fc;min-height:60vh}.mine-card{background:#fff;border-radius:15px;padding:20px;margin-bottom:14px;border:1px solid #e8edf2}.status{display:inline-block;padding:5px 10px;border-radius:20px;background:#edf3f8;font-size:12px;font-weight:700}.status-published{background:#e5faef;color:#08784f}.status-pending{background:#fff4d8;color:#8b6400}.status-rejected,.status-hidden{background:#ffe9e9;color:#a72a2a}</style>
<section class="mine-head"><div class="container d-flex justify-content-between align-items-center"><div><h1>Bài của tôi</h1><p class="mb-0">Theo dõi bản nháp, trạng thái duyệt và bài đã lưu.</p></div><a asp-action="Create" class="btn btn-primary">Viết bài mới</a></div></section>
<section class="mine-wrap"><div class="container">@if(TempData["CommunitySuccess"] is string s){<div class="alert alert-success">@s</div>}<div class="row"><div class="col-lg-8"><h4 class="mb-3">Bài đã viết</h4>
@if(!Model.Items.Any()){<div class="mine-card">Bạn chưa viết bài nào.</div>}
@foreach(var p in Model.Items){var css=p.Status=="Đã xuất bản"?"published":p.Status=="Chờ duyệt"?"pending":p.Status=="Bị từ chối"?"rejected":p.Status=="Đã ẩn"?"hidden":"draft";<div class="mine-card"><div class="d-flex justify-content-between"><span class="status status-@css">@p.Status</span><small>@p.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small></div><h5 class="mt-2">@if(p.Status=="Đã xuất bản"){<a asp-action="Details" asp-route-id="@p.CommunityPostID">@p.Title</a>}else{@p.Title}</h5><div class="text-muted">@p.Category · 👍 @p.UsefulCount · 💬 @p.CommentCount</div>
<div class="mt-3 d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@p.CommunityPostID" class="btn btn-sm btn-outline-primary">Sửa</a>
    <form asp-action="Delete" asp-route-id="@p.CommunityPostID" method="post" onsubmit="return confirm('Ẩn bài viết này khỏi Cộng đồng?');">
        @Html.AntiForgeryToken()<button type="submit" class="btn btn-sm btn-outline-danger">Ẩn bài</button>
    </form>
</div>
@if(!string.IsNullOrWhiteSpace(p.ModerationReason)){<div class="alert alert-warning mt-2 mb-0"><b>Phản hồi kiểm duyệt:</b> @p.ModerationReason</div>}</div>}
</div><aside class="col-lg-4"><h4 class="mb-3">Đã lưu</h4>@if(!Model.Bookmarks.Any()){<div class="mine-card">Chưa lưu bài nào.</div>}@foreach(var b in Model.Bookmarks){<div class="mine-card"><a asp-action="Details" asp-route-id="@b.CommunityPostID"><b>@b.Title</b></a><div class="text-muted small">@b.Category</div></div>}</aside></div></div></section>