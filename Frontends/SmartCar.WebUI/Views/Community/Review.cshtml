@model SmartCar.WebUI.Models.CommunityPostDetailViewModel
@{ Layout = "~/Views/UILayout/Index.cshtml"; ViewData["Title"] = "Xem xét bài viết"; }
<style>.review-hero{padding:110px 0 34px;background:#142f4f;color:#fff}.review-wrap{padding:36px 0;background:#f5f7fa;min-height:65vh}.review-card{background:#fff;border-radius:14px;padding:25px;box-shadow:0 6px 22px rgba(15,45,75,.08)}.post-body{white-space:pre-wrap;line-height:1.8}.meta{color:#637080;font-size:14px}.label{padding:5px 10px;background:#edf3f8;border-radius:18px;font-size:12px;font-weight:600}</style>
<section class="review-hero"><div class="container"><a asp-action="Moderation" class="text-white">← Hàng đợi kiểm duyệt</a><h1 class="text-white mt-3">Xem xét bài viết</h1><p class="mb-0">Đọc toàn bộ nội dung trước khi quyết định.</p></div></section>
<section class="review-wrap"><div class="container"><div class="row"><main class="col-lg-8"><article class="review-card"><div class="d-flex justify-content-between flex-wrap gap-2"><span class="label">@Model.Status</span><span class="label">@Model.ReportCount báo cáo mới</span></div><h2 class="mt-3">@Model.Title</h2><div class="meta mb-3">@Model.AuthorName · @Model.Category · @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
@if(!string.IsNullOrWhiteSpace(Model.CoverImageUrl)){<img src="@Model.CoverImageUrl" alt="" class="img-fluid rounded mb-4" />}
<div class="post-body">@Model.Content</div>
@if(Model.Comments.Any()){<hr/><h5>Bình luận (@Model.Comments.Count)</h5>@foreach(var comment in Model.Comments){<div class="border rounded p-3 mb-2"><b>@comment.AuthorName</b><small class="text-muted"> · @comment.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</small><div class="mt-1">@comment.Content</div></div>}}</article></main>
<aside class="col-lg-4 mt-3 mt-lg-0"><div class="review-card"><h4>Quyết định</h4><p class="meta">Khi ẩn hoặc từ chối, hãy nêu lý do cụ thể để tác giả biết cách xử lý.</p>
<form asp-action="Moderate" asp-route-id="@Model.CommunityPostID" method="post">@Html.AntiForgeryToken()<div class="form-group"><label for="reason">Ghi chú kiểm duyệt</label><textarea id="reason" name="reason" class="form-control" rows="4" maxlength="500" placeholder="Bắt buộc khi từ chối hoặc ẩn bài">@Model.ModerationReason</textarea></div>
<div class="d-grid gap-2"><button name="action" value="Xuất bản" class="btn btn-success w-100 mb-2">Duyệt đăng</button><button name="action" value="Từ chối" class="btn btn-warning w-100 mb-2">Từ chối</button><button name="action" value="Ẩn" class="btn btn-danger w-100 mb-2">Ẩn bài</button>@if(Model.IsCommentsLocked){<button name="action" value="Mở bình luận" class="btn btn-outline-secondary w-100">Mở bình luận</button>}else{<button name="action" value="Khóa bình luận" class="btn btn-outline-secondary w-100">Khóa bình luận</button>}</div></form></div></aside></div></div></section>