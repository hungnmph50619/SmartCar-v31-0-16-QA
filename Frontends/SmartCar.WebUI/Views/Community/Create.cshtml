@model SmartCar.WebUI.Models.CommunityPostFormViewModel
@{ Layout = "~/Views/UILayout/Index.cshtml"; ViewData["Title"]="Viết bài cộng đồng"; }
<style>.write-hero{padding:120px 0 40px;background:#f0f7ff}.write-wrap{padding:38px 0;background:#f7f9fc}.write-card{background:#fff;border-radius:18px;padding:30px;box-shadow:0 8px 28px rgba(15,45,75,.08)}.steps{display:flex;gap:10px;flex-wrap:wrap}.step{flex:1;min-width:140px;padding:13px;border-radius:12px;background:#eef5fb;font-size:13px}.rules{background:#fff8e8;border-radius:12px;padding:16px}</style>
<section class="write-hero"><div class="container"><h1>Chia sẻ với cộng đồng</h1><div class="steps"><div class="step"><b>1. Chọn chủ đề</b><br/>Giúp mọi người tìm bài</div><div class="step"><b>2. Viết rõ ràng</b><br/>Không nêu dữ liệu riêng tư</div><div class="step"><b>3. Thêm minh chứng</b><br/>Gắn chuyến đi nếu có</div><div class="step"><b>4. Gửi duyệt</b><br/>Bài mới có thể cần kiểm tra</div></div></div></section>
<section class="write-wrap"><div class="container"><div class="row"><div class="col-lg-8"><form asp-action="Create" method="post" enctype="multipart/form-data" class="write-card">
@Html.AntiForgeryToken()<div asp-validation-summary="All" class="text-danger"></div>
<div class="form-group"><label asp-for="Title">Tiêu đề *</label><input asp-for="Title" class="form-control" placeholder="Ví dụ: Kinh nghiệm nhận xe tại sân bay Nội Bài" /><span asp-validation-for="Title" class="text-danger"></span></div>
<div class="row"><div class="col-md-6 form-group"><label asp-for="Category">Chủ đề *</label><select asp-for="Category" class="form-control">@foreach(var c in Model.Categories){<option value="@c">@c</option>}</select></div>
<div class="col-md-6 form-group"><label asp-for="LocationName">Địa điểm (không bắt buộc)</label><input asp-for="LocationName" class="form-control" placeholder="Quận, tỉnh/thành..." /></div></div>
<div class="form-group"><label asp-for="ReservationID">Chuyến đi liên quan</label><select asp-for="ReservationID" class="form-control"><option value="">Không gắn chuyến đi</option>@foreach(var t in Model.Trips){<option value="@t.ReservationID">@t.CarName · @t.PickUpDate.ToString("dd/MM/yyyy")</option>}</select><small class="text-muted">Gắn chuyến đã hoàn thành để nhận nhãn “Chuyến đi đã xác minh”.</small></div>
<div class="form-group"><label asp-for="Content">Nội dung *</label><textarea asp-for="Content" rows="12" class="form-control" placeholder="Mô tả trải nghiệm, câu hỏi hoặc lời khuyên của bạn..."></textarea><small class="text-muted"><span id="charCount">0</span>/12.000 ký tự · tối thiểu 50 ký tự</small></div>
<div class="form-group"><label asp-for="CoverImage">Ảnh bìa</label><input asp-for="CoverImage" type="file" accept=".jpg,.jpeg,.png,.webp" class="form-control-file" /><small class="text-muted">JPG, PNG, WEBP; tối đa 5 MB.</small></div>
@if(User.IsInRole("Admin")){<div class="form-check mb-3"><input asp-for="IsOfficial" class="form-check-input"/><label asp-for="IsOfficial" class="form-check-label">Đăng với nhãn SmartCar chính thức</label></div>}
<div class="rules mb-3"><b>Trước khi đăng:</b> Không chia sẻ số điện thoại, CCCD, tài khoản ngân hàng; không xúc phạm, quảng cáo rác hoặc cung cấp thông tin sai lệch.</div>
<button type="submit" name="Submit" value="false" class="btn btn-outline-secondary mr-2">Lưu bản nháp</button><button type="submit" name="Submit" value="true" class="btn btn-primary">Gửi đăng bài</button>
</form></div><aside class="col-lg-4"><div class="write-card"><h5>Bài nào được đăng ngay?</h5><p>Thành viên có chuyến đi đã hoàn thành, chủ xe đã xác minh và quản trị viên có mức tin cậy cao hơn. Bài đầu tiên của tài khoản khác sẽ được nhân viên kiểm tra.</p><p class="mb-0"><b>Lưu ý:</b> SmartCar có thể ẩn bài vi phạm và lưu lịch sử kiểm duyệt.</p></div></aside></div></div></section>
<script>const c=document.getElementById('Content'),n=document.getElementById('charCount');function count(){n.textContent=c.value.length.toLocaleString('vi-VN')}c.addEventListener('input',count);count();</script>