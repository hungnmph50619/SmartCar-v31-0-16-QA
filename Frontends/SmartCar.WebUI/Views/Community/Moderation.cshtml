@model List<SmartCar.WebUI.Models.CommunityModerationViewModel>
@{ Layout = "~/Views/UILayout/Index.cshtml"; ViewData["Title"]="Kiểm duyệt cộng đồng"; }
<style>.mod-head{padding:120px 0 35px;background:#142f4f;color:white}.mod-wrap{padding:38px 0;background:#f5f7fa;min-height:65vh}.mod-card{background:white;padding:22px;border-radius:15px;margin-bottom:15px;border-left:5px solid #ffb020}.pill{padding:5px 10px;background:#edf3f8;border-radius:20px;font-size:12px}</style>
<section class="mod-head"><div class="container"><h1 class="text-white">Kiểm duyệt cộng đồng</h1><p>Ưu tiên bài chờ duyệt và nội dung được báo cáo.</p></div></section><section class="mod-wrap"><div class="container">@if(TempData["CommunitySuccess"] is string s){<div class="alert alert-success">@s</div>}@if(TempData["CommunityError"] is string e){<div class="alert alert-danger">@e</div>}
@if(!Model.Any()){<div class="alert alert-success">Không có nội dung cần xử lý.</div>}
@foreach(var p in Model){<div class="mod-card"><div class="d-flex justify-content-between flex-wrap"><div><span class="pill">@p.Status</span><span class="pill ml-1">@p.ReportCount báo cáo</span><h4 class="mt-2">@p.Title</h4><div class="text-muted">@p.AuthorName · @p.Category · @p.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div></div><a asp-action="Details" asp-route-id="@p.CommunityPostID" target="_blank">Xem bài</a></div>
<form asp-action="Moderate" asp-route-id="@p.CommunityPostID" method="post" class="mt-3">@Html.AntiForgeryToken()<div class="row"><div class="col-lg-6"><input name="reason" class="form-control" maxlength="500" placeholder="Lý do (bắt buộc khi từ chối/ẩn)"/></div><div class="col-lg-6 mt-2 mt-lg-0"><button name="action" value="Xuất bản" class="btn btn-success">Duyệt đăng</button> <button name="action" value="Từ chối" class="btn btn-warning">Từ chối</button> <button name="action" value="Ẩn" class="btn btn-danger">Ẩn bài</button> <button name="action" value="Khóa bình luận" class="btn btn-secondary">Khóa bình luận</button></div></div></form></div>}
</div></section>