@model SmartCar.WebUI.Models.CommunityPostDetailViewModel
@{ Layout = "~/Views/UILayout/Index.cshtml"; ViewData["Title"]=Model.Title; var roots=Model.Comments.Where(x=>x.ParentCommentID==null).ToList(); }
<style>.detail-head{padding:120px 0 45px;background:#eef6ff}.detail-wrap{padding:40px 0;background:#f8fafc}.article-card,.side-card{background:#fff;border-radius:18px;padding:28px;border:1px solid #e7edf3}.article-cover{width:100%;max-height:480px;object-fit:cover;border-radius:14px;margin:20px 0}.article-content{white-space:pre-line;font-size:17px;line-height:1.85}.comment{padding:17px;border-radius:12px;background:#f5f8fb;margin-bottom:12px}.reply{margin-left:42px;border-left:3px solid #b8d7f3}.label{display:inline-block;padding:6px 10px;border-radius:18px;background:#e8f4ff;color:#0874c9;font-weight:700;font-size:12px}</style>
<section class="detail-head"><div class="container"><span class="label">@(Model.IsOfficial ? "SmartCar chính thức" : Model.Category)</span><h1 class="mt-3">@Model.Title</h1><p class="mb-0">Bởi @Model.AuthorName @(Model.IsVehiclePartner ? "· Chủ xe đã xác minh" : "") · @((Model.PublishedAt ?? Model.CreatedAt).ToString("dd/MM/yyyy HH:mm"))</p></div></section>
<section class="detail-wrap"><div class="container">@if(TempData["CommunitySuccess"] is string s){<div class="alert alert-success">@s</div>}@if(TempData["CommunityError"] is string e){<div class="alert alert-danger">@e</div>}
<div class="row"><article class="col-lg-8"><div class="article-card">@if(!string.IsNullOrWhiteSpace(Model.CoverImageUrl)){<img src="@Model.CoverImageUrl" class="article-cover" alt="@Model.Title"/>}<div class="article-content">@Model.Content</div>
@if(!string.IsNullOrWhiteSpace(Model.LocationName)){<p class="mt-3"><b>Địa điểm:</b> @Model.LocationName</p>}@if(Model.ReservationID.HasValue){<div class="alert alert-success">✓ Nội dung gắn với chuyến đi đã hoàn thành.</div>}
<div class="alert alert-light border mt-4">@(Model.IsOfficial ? "Đây là nội dung chính thức của SmartCar." : "Đây là nội dung do thành viên chia sẻ; không đại diện cho cam kết chính thức của SmartCar.")</div>
<div class="d-flex flex-wrap mt-3"><form asp-action="Useful" asp-route-id="@Model.CommunityPostID" method="post" class="mr-2">@Html.AntiForgeryToken()<button class="btn btn-outline-primary">👍 Hữu ích (@Model.UsefulCount)</button></form><form asp-action="Bookmark" asp-route-id="@Model.CommunityPostID" method="post">@Html.AntiForgeryToken()<button class="btn btn-outline-secondary">🔖 Lưu bài</button></form></div></div>
<div class="article-card mt-4"><h3>Thảo luận (@Model.Comments.Count)</h3>
@if(Model.IsCommentsLocked){<div class="alert alert-warning">Bình luận đã bị khóa bởi người kiểm duyệt.</div>}else if(User.Identity?.IsAuthenticated==true){<form asp-action="Comment" asp-route-id="@Model.CommunityPostID" method="post" class="mb-4">@Html.AntiForgeryToken()<textarea name="content" class="form-control mb-2" rows="3" maxlength="2000" required placeholder="Viết bình luận có ích và tôn trọng..."></textarea><button class="btn btn-primary">Gửi bình luận</button></form>}else{<div class="alert alert-info"><a href="/Login/Index">Đăng nhập</a> để tham gia thảo luận.</div>}
@foreach(var c in roots){<div class="comment"><b>@c.AuthorName</b> @if(c.IsVehiclePartner){<span class="label">Chủ xe</span>}<small class="text-muted ml-2">@c.CreatedAt.ToString("dd/MM HH:mm")</small><div>@c.Content</div>
@if(!Model.IsCommentsLocked && User.Identity?.IsAuthenticated==true){<details class="mt-2"><summary>Trả lời</summary><form asp-action="Comment" asp-route-id="@Model.CommunityPostID" method="post" class="mt-2">@Html.AntiForgeryToken()<input type="hidden" name="parentCommentID" value="@c.CommunityCommentID"/><textarea name="content" class="form-control mb-2" rows="2" maxlength="2000" required></textarea><button class="btn btn-sm btn-primary">Gửi</button></form></details>}</div>
@foreach(var r in Model.Comments.Where(x=>x.ParentCommentID==c.CommunityCommentID)){<div class="comment reply"><b>@r.AuthorName</b><small class="text-muted ml-2">@r.CreatedAt.ToString("dd/MM HH:mm")</small><div>@r.Content</div></div>}}
</div></article><aside class="col-lg-4"><div class="side-card"><h5>An toàn cộng đồng</h5><p>Nếu bài có thông tin cá nhân, quảng cáo rác, lừa đảo hoặc xúc phạm, hãy báo cho SmartCar.</p>
@if(User.Identity?.IsAuthenticated==true){<details><summary class="btn btn-outline-danger">Báo cáo bài viết</summary><form asp-action="Report" asp-route-id="@Model.CommunityPostID" method="post" class="mt-3">@Html.AntiForgeryToken()<select name="reason" class="form-control mb-2" required><option value="">Chọn lý do</option><option>Thông tin cá nhân</option><option>Lừa đảo</option><option>Quảng cáo rác</option><option>Xúc phạm/quấy rối</option><option>Thông tin sai lệch</option></select><textarea name="detail" class="form-control mb-2" maxlength="500" placeholder="Mô tả thêm"></textarea><button class="btn btn-danger btn-block">Gửi báo cáo</button></form></details>}</div></aside></div></div></section>