@model List<ResultCarPricingListWithModelDto>
@{
    ViewData["Title"] = "Bảng giá thuê xe";
    Layout = "~/Views/UILayout/Index.cshtml";
}

<style>
    /* Hiển thị VNĐ sau số tiền, tránh CSS gốc đặt thẻ small chồng lên con số. */
    .table tbody tr td.price h3 {
        white-space: nowrap;
        margin-bottom: 0;
    }

    .table tbody tr td.price h3 .price-vnd {
        display: inline-flex;
        align-items: baseline;
        gap: 4px;
        color: #1089ff;
    }

    .table tbody tr td.price h3 .amount {
        font-size: 18px;
        line-height: 1.2;
    }

    .table tbody tr td.price h3 .currency-vnd {
        position: static !important;
        font-size: 12px;
        line-height: 1;
    }

    .table tbody tr td.price h3 .per {
        display: block;
        margin-top: 5px;
    }
</style>

<section class="ftco-section ftco-cart">
    <div class="container">
        <div class="row">
            <div class="col-md-12 ftco-animate">
                @if (!string.IsNullOrWhiteSpace(ViewBag.ErrorMessage as string))
                {
                    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
                }
                @if (Model == null || Model.Count == 0)
                {
                    <div class="alert alert-warning">Chưa có dữ liệu bảng giá.</div>
                }
                <div class="car-list">
                    <table class="table">
                        <thead class="thead-primary">
                            <tr class="text-center">
                                <th>&nbsp;</th>
                                <th>&nbsp;</th>
                                <th class="bg-primary heading">Giá thuê theo ngày</th>
                                <th class="bg-dark heading">Giá thuê theo tuần</th>
                                <th class="bg-black heading">Giá thuê theo tháng</th>
                            </tr>
                        </thead>
                        @foreach (var item in Model ?? new List<ResultCarPricingListWithModelDto>())
                        {
                            <tbody>
                                <tr class="">
                                    <td class="car-image"><div class="img" style="background-image:url(@item.CoverImageUrl);"></div></td>
                                    <td class="product-name">
                                        <h3>@item.Brand @item.model</h3>
                                        <p class="mb-0 rated">
                                            <span>Điểm:</span>
                                            <span class="ion-ios-star"></span>
                                            <span class="ion-ios-star"></span>
                                            <span class="ion-ios-star"></span>
                                            <span class="ion-ios-star"></span>
                                            <span class="ion-ios-star"></span>
                                        </p>
                                    </td>

                                    <td class="price">
                                        <p class="btn-custom"><a href="/Reservation/Index/@item.carId">Thuê chiếc xe này</a></p>
                                        <div class="price-rate">
                                            <h3>
                                                <span class="price-vnd">
                                                    <span class="amount">@item.dailyAmount.ToString("#,0", CultureInfo.InvariantCulture)</span>
                                                    <span class="currency-vnd">VNĐ</span>
                                                </span>
                                                <span class="per">/ngày</span>
                                            </h3>
                                        </div>
                                    </td>

                                    <td class="price">
                                        <p class="btn-custom"><a href="/Reservation/Index/@item.carId">Thuê chiếc xe này</a></p>
                                        <div class="price-rate">
                                            <h3>
                                                <span class="price-vnd">
                                                    <span class="amount">@item.weeklyAmount.ToString("#,0", CultureInfo.InvariantCulture)</span>
                                                    <span class="currency-vnd">VNĐ</span>
                                                </span>
                                                <span class="per">/tuần</span>
                                            </h3>
                                        </div>
                                    </td>

                                    <td class="price">
                                        <p class="btn-custom"><a href="/Reservation/Index/@item.carId">Thuê chiếc xe này</a></p>
                                        <div class="price-rate">
                                            <h3>
                                                <span class="price-vnd">
                                                    <span class="amount">@item.monthlyAmount.ToString("#,0", CultureInfo.InvariantCulture)</span>
                                                    <span class="currency-vnd">VNĐ</span>
                                                </span>
                                                <span class="per">/tháng</span>
                                            </h3>
                                        </div>
                                    </td>
                                </tr><!-- END TR-->
                            </tbody>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>
